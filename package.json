{
  "name": "ruth-and-nora-dressup",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "generate:sprites": "python3 scripts/generate_pixel_atlases.py",
    "test:tools": "python3 tools/tests/run_tools_tests.py",
    "setup:ai-news-env": "python3 tools/setup_ai_news_env.py",
    "verify:ai-news-env": "python3 tools/setup_ai_news_env.py --verify-only",
    "setup:security-audit-env": "python3 tools/setup_security_audit_env.py",
    "verify:security-audit-env": "python3 tools/setup_security_audit_env.py --verify-only",
    "setup:python-tools": "bash scripts/setup_python_tools.sh",
    "verify:python-tools": "bash scripts/setup_python_tools.sh --verify-only"
  },
  "dependencies": {
    "@pixi/react": "^7.1.2",
    "pixi.js": "^7.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
